# OneThingAI 凭据 —— 仅服务端使用，禁止加 NEXT_PUBLIC_ 前缀
ONETHING_API_KEY=your_onething_api_key
ONETHING_WORKFLOW_INSTANCE_ID=your_workflow_instance_id

# 可选：OneThingAI API Base URL（接入真实 API 时填写）
# ONETHING_BASE_URL=https://api.onethingai.com

# 适配器开关：mock（默认，返回占位图）| real（接入真实 OneThingAI）
ONETHING_PROVIDER=mock
