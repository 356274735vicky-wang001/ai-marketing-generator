# OneThingAI / ComfyOne 凭据 —— 仅服务端使用，禁止加 NEXT_PUBLIC_ 前缀
ONETHING_API_KEY=your_onething_api_key
# 已注册的工作流 ID（ComfyOne /v1/workflows 返回的 id）
ONETHING_WORKFLOW_INSTANCE_ID=your_workflow_id

# 适配器开关：mock（默认，本地合成占位图）| real（接入真实 ComfyOne）
ONETHING_PROVIDER=mock

# 可选：ComfyOne API Base URL（默认即下方地址，一般无需改）
# ONETHING_BASE_URL=https://pandora-server-cf.onethingai.com
# 可选：指定运行的 GPU 后端实例
# ONETHING_BACKEND_ID=your_backend_instance_id
# 可选：真实接口失败时是否回退 Mock（true/false，默认 false=返回明确错误）
# ONETHING_FALLBACK_TO_MOCK=false
# 可选：ComfyOne 外部请求详细日志（method/url/status/耗时/错误），默认 true；排查完可设 false
# ONETHING_VERBOSE=true
